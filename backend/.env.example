# ── Instagram ────────────────────────────────────────────────────────────────
# Obtener en: developers.facebook.com → Graph API Explorer → seleccionar página
IG_USER_ID=111111111111111
IG_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxIG

# ── Facebook ─────────────────────────────────────────────────────────────────
# El ID de tu página de Facebook (está en la URL de la página o en Configuración)
FB_PAGE_ID=222222222222222
FB_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxFB

# ── AWS / S3 Datalake ────────────────────────────────────────────────────────
S3_RAW_BUCKET=nombre-de-tu-bucket
S3_RAW_PREFIX=raw/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Clave secreta para firmar los JWT — cambiar por un valor seguro en producción
JWT_SECRET=cambia-esto-por-un-secreto-seguro
# Tiempo de expiración del token en minutos
JWT_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Orígenes permitidos para llamar al backend desde el navegador (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Chatbot Flor (F7 — Gemini RAG) ───────────────────────────────────────────
# Obtener clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu-clave-de-gemini
GEMINI_MODEL=gemini-2.5-flash
# Cuántos chunks recuperar de la base de conocimiento
CHATBOT_TOP_K=5
# Umbral mínimo de similitud (0–1) para considerar un chunk relevante
CHATBOT_MIN_SIMILARITY=0.55
# Mensaje que devuelve el chatbot cuando no encuentra una respuesta confiable
CHATBOT_FALLBACK_MESSAGE=No tengo esa respuesta. Puedes radicar un PQRSD o escribir a FLOR por WhatsApp al +57 301 604 4444.
