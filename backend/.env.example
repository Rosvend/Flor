# ── Instagram ────────────────────────────────────────────────────────────────
# Obtener en: developers.facebook.com → Graph API Explorer → seleccionar página
IG_USER_ID=111111111111111
IG_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxIG

# ── Facebook ─────────────────────────────────────────────────────────────────
# El ID de tu página de Facebook (está en la URL de la página o en Configuración)
FB_PAGE_ID=222222222222222
FB_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxFB

# ── AWS / S3 Datalake ────────────────────────────────────────────────────────
S3_RAW_BUCKET=nombre-de-tu-bucket
S3_RAW_PREFIX=raw/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Clave secreta para firmar los JWT — cambiar por un valor seguro en producción
JWT_SECRET=cambia-esto-por-un-secreto-seguro
# Tiempo de expiración del token en minutos
JWT_EXPIRE_MINUTES=60
